{
  "$comment-1": "Per-project configuration for the flow plugin. Every slot is OPTIONAL — flow ships sensible defaults. Slots you DON'T set use the documented default. Schema: https://github.com/by-dev-tools/flow/blob/main/plugins/flow/schema/flow.config.schema.json",
  "$comment-2": "DELETE THIS BLOCK AND THE $comment-* lines BEFORE COMMITTING. They are not part of the schema; they're here for the bootstrap reader.",

  "defaultBranch": "main",

  "$comment-typecheckCmd": "Shell command to run as the project's typecheck (after review fixes land). Run via sh -c, not eval. UNSET → /flow:ship prints a loud ⚠️ warning rather than silently skipping.",
  "typecheckCmd": "npm run typecheck",

  "$comment-preflightCmd": "Shell command for the project's mechanical preflight (typecheck + lint + fast tests; project owns the composition). Run via sh -c at /flow:ship Step 1c + /flow:ship-spike Step 1c with bounded fix-and-retry (N≤3). UNSET → loud ⚠️ warning, pipeline proceeds. Typical convention: node tools/preflight/check.mjs.",
  "preflightCmd": "node tools/preflight/check.mjs",

  "$comment-paths": "Doc paths used by /flow:ship for synthesis and by the reviewers for grounding. Defaults below are the consumer convention (core-docs/). Flow's own repo overrides to dev-docs/.",
  "historyPath": "core-docs/history.md",
  "planPath": "core-docs/plan.md",
  "roadmapPath": "core-docs/roadmap.md",
  "specPath": "core-docs/spec.md",
  "feedbackPath": "core-docs/feedback.md",
  "designLanguagePath": "core-docs/design-language.md",

  "$comment-statusDocs": "OPT-IN. Extra forward-looking status surfaces /flow:ship reconciles every ship beyond plan 'Current Focus' + roadmap 'Now' — e.g. a CLAUDE.md / README status line a cold agent reads. Each entry: {path, marker}. Flow edits ONLY the region between <!-- {marker} --> and <!-- /{marker} --> (a narrow, mechanical update — fence the status region in the file first). Step 5b BLOCKS a ship that moved plan/roadmap status forward but left a declared region untouched (works with NO version manifest); /flow:doctor Check 2.7 checks each is fenced. Default []. Example: [{\"path\":\"CLAUDE.md\",\"marker\":\"flow:status\"},{\"path\":\"README.md\",\"marker\":\"flow:status\"}]",
  "statusDocs": [],

  "$comment-referenceGlob": "Glob /flow:critique-plan uses to load reference docs. Excludes history/plan/roadmap automatically (those churn too often to be reliable spec sources).",
  "referenceGlob": "core-docs/*.md",

  "$comment-uiSurface": "Whether this project ships a UI. If false, /flow:accessibility-review exits early instead of running an empty audit. Backend / CLI / library projects: set to false.",
  "uiSurface": true,

  "$comment-diff-patterns": "Extended-regex (grep -E) patterns for per-diff early-exit. sourceFilePatterns: /flow:security-review skips a diff with no source files (docs-only PR). uiFilePatterns: /flow:accessibility-review skips a diff with no UI files. Both ship sensible cross-language defaults in the schema — set ONLY to override for an unusual project. Shown here so you know they exist.",
  "sourceFilePatterns": "\\.(ts|tsx|js|jsx|mjs|cjs|py|rs|swift|go|rb|java|kt|sh|bash|tf|tfvars|sql|proto|graphql|gql)$|\\.(json|ya?ml|toml)$|(^|/)(Dockerfile|Makefile)(\\.|$)",
  "uiFilePatterns": "\\.(tsx|jsx|vue|svelte|astro|mdx|css|scss|sass|less|html|njk|hbs|ejs)$",

  "$comment-reviewLenses": "Which /flow:staff-review lenses spawn in parallel. Removing a lens means it won't run — document why in your plan doc.",
  "reviewLenses": ["staff-engineer", "ux-designer", "design-engineer", "push-further"],

  "$comment-memoryHardCap": "Max failure-pattern memory entries before tools/memory/check.mjs forces curation. Most projects need < 30 if the source-diversity bar is honored.",
  "memoryHardCap": 30,

  "$comment-branchPrefix": "Conventional prefix for feature branches created by /flow:ship and /flow:ship-spike. Common: 'claude/', 'feature/', 'fix/'. Empty disables.",
  "branchPrefix": "claude/",

  "$comment-verify-build": "Controls /flow:verify-build, the runtime behavioral-verification gate at /flow:ship Step 2 (v1.3.0). platform: hint for skip-path decisions — 'library'/'none' self-skips (no runnable target); web/ios/android/tauri/cli run the verify pass; UNSET → bundled /run autodetects. verifyEnabled: project-wide on/off. verifyBudgetCalls: tool-call cap before unjudged verdicts are forced to Unknown (which gates ship). NOTE: requires a /run launch recipe — run /run-skill-generator once per project (doctor Check 5.3 surfaces the gap).",
  "platform": "web",
  "verifyEnabled": true,
  "verifyFindingsPath": "/tmp/flow-verify-findings.json",
  "verifyBudgetCalls": 60,

  "$comment-rustWorkspaceDir": "(Tauri / Rust stacks only — omit on pure web / swift / non-Rust projects.) Directory holding your Cargo workspace. Default 'src-tauri' is the Tauri convention; non-Tauri Rust projects set '.' (workspace at root) or the subdir name.",
  "rustWorkspaceDir": "src-tauri"
}
